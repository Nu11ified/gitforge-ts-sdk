{
  "name": "@gitforge/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the GitForge REST API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/webhooks/validate.d.mts",
        "default": "./dist/webhooks/validate.mjs"
      },
      "require": {
        "types": "./dist/webhooks/validate.d.ts",
        "default": "./dist/webhooks/validate.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nu11ified/gitforge-ts-sdk.git"
  },
  "license": "MIT",
  "keywords": [
    "gitforge",
    "git",
    "api",
    "sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
